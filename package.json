{
  "name": "quanta-worktime-management",
  "version": "1.0.0",
  "private": true,
  "description": "Quanta Worktime Management - QR + BLE challenge-response attendance and timesheet system",
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "onlyBuiltDependencies": ["argon2", "@nestjs/core"]
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "api:dev": "pnpm --filter @quanta/api start:dev",
    "admin:dev": "pnpm --filter @quanta/admin dev",
    "db:up": "docker compose up -d postgres",
    "db:migrate": "pnpm --filter @quanta/api migration:run",
    "db:seed": "pnpm --filter @quanta/api seed"
  }
}
